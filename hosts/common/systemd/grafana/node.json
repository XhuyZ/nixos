{
  "title": "Node + RAID Overview",
  "panels": [
    {
      "type": "stat",
      "title": "CPU Usage %",
      "targets": [
        {
          "expr": "node:cpu_usage:percent",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Memory Usage %",
      "targets": [
        {
          "expr": "node:memory_usage:percent",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Disk Usage %",
      "targets": [
        {
          "expr": "node:disk_usage:percent{mountpoint=\"/mnt/storage\"}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Disk Read (bytes/sec)",
      "targets": [
        {
          "expr": "node:disk_read_bytes:rate",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Disk Write (bytes/sec)",
      "targets": [
        {
          "expr": "node:disk_write_bytes:rate",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Disk Read IOPS",
      "targets": [
        {
          "expr": "node:disk_read_iops:rate",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Disk Write IOPS",
      "targets": [
        {
          "expr": "node:disk_write_iops:rate",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Disk IO Utilization %",
      "targets": [
        {
          "expr": "node:disk_io_util:percent",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Disk Read Latency (s)",
      "targets": [
        {
          "expr": "node:disk_read_latency:seconds",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Disk Write Latency (s)",
      "targets": [
        {
          "expr": "node:disk_write_latency:seconds",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Network RX (bytes/sec)",
      "targets": [
        {
          "expr": "node:network_receive_bytes:rate",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Network TX (bytes/sec)",
      "targets": [
        {
          "expr": "node:network_transmit_bytes:rate",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 38,
  "version": 1
}
